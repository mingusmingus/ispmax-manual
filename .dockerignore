# ─────────────────────────────────────────────────────────────
# .dockerignore — todo lo que NO debe entrar al contexto de build
#
# (El archivo `dockerignore` sin punto que había antes no lo lee
#  Docker; se conserva por historial, pero el que manda es este.)
# ─────────────────────────────────────────────────────────────

# Control de versiones
.git
.gitignore
.gitattributes
.github

# Editores / IDE
.vscode
.idea
.claude
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# Node.js — se instala dentro de la imagen con `npm ci`
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
yarn.lock

# Salidas de build (se regeneran en la etapa 1)
dist/
doc_build/
docs/public/

# Logs y temporales
*.log
*.tmp
*.bak
*.old
.cache
tmp/
temp/

# Variables de entorno (¡nunca dentro de la imagen!)
.env
.env.*
*.pem
*.key

# Documentación de desarrollo (no aporta en la imagen)
README.md
CHANGELOG.md
LICENSE

# Archivos del proceso de auditoría / backend (no son del manual)
ISPMAX_*.zip
ISPMAX_*.txt
ISPMAX_*.ps1
backend/
*.zip

# Docker (no se incluye a sí mismo en la imagen)
Dockerfile
dockerignore
docker-compose.yml
docker-compose.*.yml
.dockerignore

# Archivos de prueba o exploración
test/
tests/
playground/
sandbox/
draft/
ideas.txt

# Capturas de pantalla sueltas que no van dentro de assets/imgs/
screenshot*.png
captura*.png
prueba*.webp
